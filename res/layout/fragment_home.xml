<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:padding="16dp">

        <!-- Карточка "Ближайшее событие" — оставляем как было -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardNearestEvent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Твой существующий код карточки события остаётся без изменений -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">
                <!-- Цветная полоса слева -->
                <View
                    android:id="@+id/indicatorColor"
                    android:layout_width="6dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="12dp"
                    android:background="@color/pink"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textEventTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ближайшее событие"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"/>

                    <TextView
                        android:id="@+id/textEventDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12 октября"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/textEventType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Годовщина"
                        android:textSize="14sp"
                        android:textColor="@color/pink"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

                <!-- Иконка для перехода к деталям -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_important_dates"
                    android:contentDescription="Details"
                    android:backgroundTint="@color/black"
                    android:layout_gravity="center_vertical"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- НОВАЯ КОМПАКТНАЯ КАРТОЧКА "Сегодняшний прогресс" -->
        <androidx.cardview.widget.CardView
            android:id="@+id/todayProgressCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/cardNearestEvent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Заголовок карточки -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Сегодняшний прогресс"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />

                <!-- Градиентный прогресс-бар (точно такой же, как в DailyTasks) -->
                <ProgressBar
                    android:id="@+id/mainGradientProgressBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_marginTop="12dp"
                    android:progressDrawable="@drawable/progress_gradient"
                    android:max="100"
                    android:progress="0" />

                <!-- Статус парня (точно такой же текст и стиль) -->
                <TextView
                    android:id="@+id/mainBoyStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Статус: Идеальный ❤️"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <!-- Мини-список сегодняшних заданий -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/todayTasksRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:overScrollMode="never" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
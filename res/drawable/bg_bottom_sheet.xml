<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Цвет фона -->
    <solid android:color="@android:color/white" />

    <!-- Скругление углов -->
    <corners android:radius="24dp" />

    <!-- Внутренние отступы -->
    <padding
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp" />

    <!-- Обводка (тень) -->
    <stroke
        android:width="1dp"
        android:color="#DDDDDD" />
</shape>
